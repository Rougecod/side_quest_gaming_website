PORT=3000
SQLITE_DB_PATH=./quest.db

# Admin access
ADMIN_API_KEY=replace_with_a_long_random_key
ADMIN_PASSWORD=replace_with_a_strong_password
ADMIN_EMAIL=owner@example.com

# Email delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password

# Paytm payment gateway
PAYTM_MID=your_paytm_mid
PAYTM_MERCHANT_KEY=your_paytm_merchant_key
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CHANNEL_ID=WEB
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_ENV=staging

# Razorpay payment gateway, if used
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Public site and business details
SITE_URL=https://your-domain.example
CONTACT_EMAIL=hello@sidequestgaming.in
CONTACT_PHONE=+91 98765 43210
VENUE_ADDRESS=123 Gaming Street, Tech Park, Bangalore
UPI_ID=sidequestgaming@upi
